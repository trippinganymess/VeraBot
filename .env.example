# Copy this file to .env and fill in the values. .env is gitignored.

# Comma-separated list of Gemini API keys. The bot's GeminiKeyPool rotates
# these round-robin and applies per-(key, model) cooldowns on rate limits.
GEMINI_API_KEYS=

# Single-key alternative (used only if GEMINI_API_KEYS is empty)
# GEMINI_API_KEY=

# Optional Hugging Face token for BGE-M3 sentence embeddings.
# HF_TOKEN=

# Composer model fallback chain (tried left to right). Verified live.
VERA_COMPOSER_MODELS=gemini-3.1-flash-lite-preview,gemini-2.5-flash-lite,gemma-3-27b-it

# Stage-3 classifier fallback chain. Verified live.
VERA_CLASSIFIER_MODELS=gemma-3-12b-it,gemma-3-27b-it,gemma-3-4b-it,gemma-3-1b-it

# Cooldown tuning (seconds). Defaults are sensible.
# VERA_RATE_LIMIT_COOLDOWN_S=60
# VERA_TIMEOUT_COOLDOWN_S=10
# VERA_AUTH_FAIL_COOLDOWN_S=3600
# VERA_LLM_ATTEMPT_TIMEOUT_S=10

# Bind config
# VERA_HOST=0.0.0.0
# VERA_PORT=8080

# Set NO_LLM=1 to disable both chains (offline / CI mode).
# NO_LLM=1
